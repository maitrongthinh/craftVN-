# Auto detect text files and normalize line endings to LF for consistency
* text=auto

# Documents
*.md text eol=lf
*.txt text eol=lf

# Code
*.js text eol=lf
*.py text eol=lf
*.json text eol=lf

# Config
*.yml text eol=lf
*.yaml text eol=lf

# Keep binary files as-is
*.zip binary
*.jar binary
*.png binary
*.jpg binary
*.jpeg binary
