Generated code: """
// Step 1: Find the nearest village by searching for village-specific blocks
let villagePoi = await world.getNearestBlock(bot, "bell", 1000);
if (!villagePoi) {
    villagePoi = await world.getNearestBlock(bot, "hay_block", 500);
}
if (!villagePoi) {
    villagePoi = await world.getNearestBlock(bot, "composter", 500);
}

let buildX, buildY, buildZ;

if (villagePoi) {
    log(bot, `Found village indicator at ${villagePoi.position.x}, ${villagePoi.position.y}, ${villagePoi.position.z}!`);
    // Move near the village
    await skills.goToPosition(bot, villagePoi.position.x, villagePoi.position.y, villagePoi.position.z);
    // Build a bit offset from the village center
    buildX = villagePoi.position.x + 10;
    buildZ = villagePoi.position.z + 10;
    buildY = villagePoi.position.y;
} else {
    log(bot, "No village found nearby. Building house at current location!");
    let pos = bot.entity.position;
    buildX = Math.floor(pos.x) + 5;
    buildZ = Math.floor(pos.z) + 5;
    buildY = Math.floor(pos.y);
}

// First, craft oak planks from oak logs (need lots for floor, roof, door, etc.)
await skills.craftRecipe(bot, "oak_planks", 30); // 30 crafts = 120 planks from 30 logs

// Craft oak slabs for the roof
await skills.craftRecipe(bot, "oak_slab", 10);

// Go to build site
await skills.goToPosition(bot, buildX, buildY, buildZ);

// --- BUILD THE HOUSE (7x7 exterior, 5x5 interior) ---
// Step 2: Oak plank floor (5x5 interior)
for (let dx = 1; dx <= 5; dx++) {
    for (let dz = 1; dz <= 5; dz++) {
        await skills.placeBlock(bot, "oak_planks", buildX + dx, buildY, buildZ + dz);
    }
}

// Step 3: Cobblestone walls (4 high, with a door gap on front)
for (let h = 1; h <= 4; h++) {
    for (let dx = 0; dx <= 6; dx++) {
        for (let dz = 0; dz <= 6; dz++) {
            // Only place on edges (walls)
            if (dx === 0 || dx === 6 || dz === 0 || dz === 6) {
                // Leave door opening at front center (dx=3, dz=0, h=1 and h=2)
                if (dz === 0 && dx === 3 && (h === 1 || h === 2)) continue;
                await skills.placeBlock(bot, "cobblestone", buildX + dx, buildY + h, buildZ + dz);
            }
        }
    }
}

// Step 4: Oak plank roof (flat on top)
for (let dx = 0; dx <= 6; dx++) {
    for (let dz = 0; dz <= 6; dz++) {
        await skills.placeBlock(bot, "oak_planks", buildX + dx, buildY + 5, buildZ + dz);
    }
}

// Step 5: Place door
await skills.craftRecipe(bot, "oak_door", 1);
await skills.placeBlock(bot, "oak_door", buildX + 3, buildY + 1, buildZ, 'side');

