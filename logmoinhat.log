                        continue;
                    }
                    await skills.placeBlock(bot, "cobblestone", x, y, z);
                }
            }
        }
    }

    // Step 3: Place oak plank roof at y=83
    bot.chat("Building the roof...");
    for (let x = startX; x <= endX; x++) {
        for (let z = startZ; z <= endZ; z++) {
            await skills.placeBlock(bot, "oak_planks", x, roofY, z);
        }
    }

    // Step 4: Place door
    bot.chat("Placing the door...");
    await skills.placeBlock(bot, "oak_door", doorX, wallBaseY, doorZ);

    // Step 5: Craft and place furniture inside
    bot.chat("Furnishing the interior...");

    // Crafting table
    await skills.craftRecipe(bot, "crafting_table", 1);
    await skills.placeBlock(bot, "crafting_table", -277, wallBaseY, 208);

    // Furnace
    await skills.craftRecipe(bot, "furnace", 1);
    await skills.placeBlock(bot, "furnace", -277, wallBaseY, 209);

    // Place bed
    await skills.placeBlock(bot, "white_bed", -277, wallBaseY, 212);

    // Chest
    await skills.craftRecipe(bot, "chest", 1);
    await skills.placeBlock(bot, "chest", -278, wallBaseY, 208);

    // Step 6: Place oak stairs as chairs
    bot.chat("Adding chairs...");
    await skills.placeBlock(bot, "oak_stairs", -280, wallBaseY, 209);
    await skills.placeBlock(bot, "oak_stairs", -280, wallBaseY, 211);

    // Step 7: Build garden fence and path outside
