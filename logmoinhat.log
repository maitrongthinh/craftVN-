    await skills.craftRecipe(bot, "oak_fence_gate", 1);

    // Fence line along west side (outside the house, in front of door)
    const fenceZ_start = 207;
    const fenceZ_end = 213;
    const fenceX = -284;

    for (let z = fenceZ_start; z <= fenceZ_end; z++) {
        if (z === doorZ) {
            // Place fence gate at door alignment
            await skills.placeBlock(bot, "oak_fence_gate", fenceX, wallBaseY, z);
        } else {
            await skills.placeBlock(bot, "oak_fence", fenceX, wallBaseY, z);
        }
    }

    // Path from door to fence gate
    for (let x = doorX - 1; x >= fenceX; x--) {
        await skills.placeBlock(bot, "oak_planks", x, baseY, doorZ);
    }

    // Step 8: Place buttons as decoration
    bot.chat("Adding finishing touches...");
    await skills.placeBlock(bot, "oak_button", -282, wallBaseY + 1, 209);
    await skills.placeBlock(bot, "oak_button", -282, wallBaseY + 1, 211);

    bot.chat("House is complete! 7x7 cobblestone house with oak floor, roof, door, furniture, garden fence, and path!");
}"""
